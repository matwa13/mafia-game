# Anthropic API key — not used in Phase 0; required from Phase 1 onward.
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Public base URL; defaults to http://localhost:8080 for local dev.
PUBLIC_API_URL=http://localhost:8080

# Any hex string; auto-generated if omitted.
ENCRYPTION_KEY=deadbeef

# "stub" → npc_stub, "real" → npc.lua.
MAFIA_NPC_MODE=real
MAFIA_DEV_MODE=0
MAFIA_SEED=1111
