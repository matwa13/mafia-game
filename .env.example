# Anthropic API key — not used in Phase 0; required from Phase 1 onward.
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Public base URL; defaults to http://localhost:8080 for local dev.
PUBLIC_API_URL=http://localhost:8080

# Any hex string; auto-generated if omitted.
ENCRYPTION_KEY=deadbeef

# "stub" → npc_stub, "real" → npc.lua.
MAFIA_NPC_MODE=real
MAFIA_DEV_MODE=0
MAFIA_SEED=1111

# Artificial delay (ms) between NPC LLM response and chat reveal.
# Keeps the typing bubble visible for a more game-like beat. 0 = no delay.
# Default: 2500. Capped at 30000. Malformed values fall back to default.
MAFIA_FAKE_THINKING_DELAY_MS=2500
