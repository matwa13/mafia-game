# === PRODUCTION ENV — copy to .env on the VPS. DO NOT commit this file with real secrets. ===

ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_REAL_KEY

# Set to the public HTTPS domain Caddy serves. Used by the frontend build.
PUBLIC_API_URL=https://mafia.example.com

# Generate: openssl rand -hex 32
ENCRYPTION_KEY=REPLACE_WITH_RANDOM_HEX_32

MAFIA_NPC_MODE=real
MAFIA_DEV_MODE=0          # MUST be 0 in production. Setting 1 leaks NPC internals.
# MAFIA_SEED=             # Omit for random seed per game. Set only for debugging.
MAFIA_FAKE_THINKING_DELAY_MS=2500

# D-09 (Phase 8): header Caddy forwards as authenticated username.
# Must match the Caddyfile header_up directive name exactly.
MAFIA_AUTH_HEADER=X-Authenticated-User

# D-11 (Phase 8): comma-separated allowed WebSocket origins.
# Must include the HTTPS domain without trailing slash.
MAFIA_WS_ALLOWED_ORIGINS=https://mafia.example.com
