# === PRODUCTION ENV — copy to .env on the VPS. DO NOT commit this file with real secrets. ===

ANTHROPIC_API_KEY=

# Set to the public HTTPS domain Caddy serves. Used by the frontend build.
PUBLIC_API_URL=https://mafia.matwa.site

# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

MAFIA_NPC_MODE=real
MAFIA_DEV_MODE=0          # MUST be 0 in production. Setting 1 leaks NPC internals.
# MAFIA_SEED=             # Omit for random seed per game. Set only for debugging.
MAFIA_FAKE_THINKING_DELAY_MS=2500

# D-09 (Phase 8): header Caddy forwards as authenticated username.
# Must match the Caddyfile header_up directive name exactly.
MAFIA_AUTH_HEADER=X-Authenticated-User

# D-11 (Phase 8): comma-separated allowed WebSocket origins.
# Must include the HTTPS domain without trailing slash.
MAFIA_WS_ALLOWED_ORIGINS=https://mafia.matwa.site

# === Operator-facing (NOT read by the app) ===

# D-01 (Phase 8): public hostname Caddy serves. Used by scripts/p8-smoke.sh
# full mode and DEPLOY-RUNBOOK smoke commands. Must match the site label
# in /etc/caddy/Caddyfile and the CSP connect-src wss://… directive.
# Example: mafia.example.com
MAFIA_HOST=mafia.matwa.site

# D-03 (Phase 8): the list of teammate credentials lives in the Caddyfile,
# NOT in this .env. Caddy reads its own basic_auth block on reload. Rotate
# by editing /etc/caddy/Caddyfile (paste new $2a$14$... bcrypt hashes from
# `caddy hash-password`) and `systemctl reload caddy`.
# This comment is here so an operator searching the env file for "auth"
# is pointed at the right config surface — there is no BASIC_AUTH_USERS
# env var to set.
# BASIC_AUTH_USERS=<managed in /etc/caddy/Caddyfile basic_auth block>
